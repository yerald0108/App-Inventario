                {/* Propina — solo si hubo */}
                {item.propina > 0 && (
                  <View style={estilosLocal.filaPropina}>
                    <Ionicons name="star" size={13} color="#b7791f" />
                    <Text style={estilosLocal.textoPropina}>
                      Propina: {formatCUP(item.propina)} CUP
                    </Text>
                  </View>
